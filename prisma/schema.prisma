// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  extensions = [pg_trgm]
}

model User {
  id        String  @id @default(uuid())
  username  String  @db.VarChar(40)
  email     String  @unique
  password  String  @db.VarChar(255)
  score     Int     @default(0)

  judgements                  PlayerJudgment[]
  imageClassificationRounds   ImageClassificationRound[]
  
  players   Player[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model Admin {
  id        String  @id @default(uuid())
  name      String  @db.VarChar(60)
  email     String  @unique
  password  String  @db.VarChar(255)

  evaluatedProvider AIProvider[]
  uploadedImages    Image[]       

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model Message {
  id                  String        @id @default(uuid())
  content             String        @db.Text
  creationDurationMs  Int  

  playerId            String
  player              Player        @relation(fields: [playerId], references: [id])

  sessionId           String
  session             ChatSession   @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlayerJudgment {
  id          String      @id @default(uuid())
  turingRate  Float     

  judgeId     String
  judge       User        @relation(fields: [judgeId], references: [id])

  judgedId    String
  judged      Player      @relation(fields: [judgedId], references: [id])

  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProviderStatusEnum {
  APPROVED
  REVOKED
  PENDING
}

model AIProvider {
  id        String              @id @default(uuid()) 
  name      String              @db.VarChar(60) @unique
  baseURL   String 
  email     String              @unique
  password  String              @db.VarChar(255)
  status    ProviderStatusEnum  @default(PENDING)

  admin_id  String?
  admin     Admin?              @relation(fields: [admin_id], references: [id])

  models    AIModel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

enum AIModelType {
  LANGUAGE_MODEL
  IMAGE_GENERATION_MODEL
}

model AIModel {
  id          String      @id @default(uuid()) 
  name        String      @db.VarChar(256) @unique
  score       Int         @default(0)
  pathURL     String      @db.VarChar(64)
  apiKey      String

  providerId  String
  provider    AIProvider  @relation(fields: [providerId], references: [id])

  type        AIModelType

  players     Player[]

  imagesGenerated   Image[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

enum HumanOrAIEnum {
    HUMAN
    AI
}

model Image {
  id        String  @id @default(uuid()) 

  imageURL  String
  score     Int     @default(0)
  isAI      HumanOrAIEnum 

  fromModelId   String?
  fromModel     AIModel? @relation(fields: [fromModelId], references: [id])

  fromAdminId   String?
  fromAdmin     Admin?    @relation(fields: [fromAdminId], references: [id])

  categoryId    String
  category      GenContentCategory  @relation(fields: [categoryId], references: [id])

  rounds  ImageClassificationRound[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model GenContentCategory {
  id          String  @id @default(uuid()) 
  name        String  @unique @db.VarChar(40)
  basePrompt  String  @db.VarChar(1024)

  images Image[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model ImageClassificationRound {
  id    String  @id @default(uuid()) 

  userAnswer      HumanOrAIEnum
  timeToAnswerMs  Int

  imageId   String  @unique
  image     Image   @relation(fields: [imageId], references: [id])  

  userId    String
  user      User    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatSession {
  id          String    @id @default(uuid()) 
  startedAt   DateTime 
  endedAt     DateTime?

  messages    Message[]

  player1Id   String
  player1     Player    @relation("Player1Session", fields: [player1Id], references: [id])

  player2Id   String
  player2     Player    @relation("Player2Session", fields: [player2Id], references: [id])

  player_judgment   PlayerJudgment[] 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Player {
  id                  String            @id @default(uuid())
  type                HumanOrAIEnum

  userId              String?
  user                User?              @relation(fields: [userId], references: [id], onDelete: Cascade)

  aiId                String?
  ai                  AIModel?           @relation(fields: [aiId], references: [id], onDelete: Cascade)

  messages            Message[]       
  sessionAsPlayer1    ChatSession[]     @relation("Player1Session")
  sessionAsPlayer2    ChatSession[]     @relation("Player2Session")
  judgment            PlayerJudgment[]
}